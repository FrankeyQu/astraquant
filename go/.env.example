# Copy to `.env` and fill in real secrets. `.env` is already gitignored.

# --- LLM provider (etc/llm.yaml) ---
# API key for the Zenmux-compatible LLM gateway used by the service.
# Referenced by etc/llm.yaml as ${ZENMUX_API_KEY}
ZENMUX_API_KEY=your-llm-api-key

# --- Exchange credentials (SecretStore + etc/exchange.yaml) ---
# SecretStore lookup key shape:
#   trader_id / session_id / provider / secret_name
#
# For local development, etc/exchange.yaml sets provider=hyperliquid and reads
# trader_id/session_id from ASTRAQUANT_TRADER_ID and ASTRAQUANT_SESSION_ID.
# EnvStore checks the most specific key first, then provider-level fallback:
#   ASTRAQUANT_SECRET_<TRADER_ID>_<SESSION_ID>_HYPERLIQUID_PRIVATE_KEY
#   ASTRAQUANT_SECRET_<TRADER_ID>_HYPERLIQUID_PRIVATE_KEY
#   ASTRAQUANT_SECRET_HYPERLIQUID_PRIVATE_KEY
#   ASTRAQUANT_HYPERLIQUID_PRIVATE_KEY
#   HYPERLIQUID_PRIVATE_KEY              # legacy local fallback only
ASTRAQUANT_TRADER_ID=local_trader
ASTRAQUANT_SESSION_ID=local_session

# Hex-encoded private key for Hyperliquid trading. Prefer ASTRAQUANT_* names.
ASTRAQUANT_HYPERLIQUID_PRIVATE_KEY=ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff

# Legacy fallback supported for local dev; leave empty when using ASTRAQUANT_*.
HYPERLIQUID_PRIVATE_KEY=

# Optional delegated signer (vault) EVM-style address, 0x-prefixed.
# Referenced by etc/exchange.yaml as ${HYPERLIQUID_VAULT_ADDRESS}
HYPERLIQUID_VAULT_ADDRESS=

# Main account address (for API wallet scenarios)
HYPERLIQUID_MAIN_ADDRESS=0x1b673761f69Ff78C9C8aDCA4c351574dc873105E

# --- Database and cache (override main config via env) ---
# These environment variables map to internal/config.Config via go-zero
# `conf.UseEnv()`; they override values in etc/nof0.yaml when exported.
# Note: go-zero expects the double-underscore (Parent__Field) naming.
#
# IMPORTANT: Add default_query_exec_mode=simple_protocol to avoid prepared statement conflicts
# when using pgx driver, especially with connection poolers or concurrent queries.
# See docs/environment-config.md for detailed explanation.
Postgres__DataSource=postgres://nof0:nof0@localhost:5432/nof0?sslmode=disable&default_query_exec_mode=simple_protocol
Postgres__MaxOpen=25
Postgres__MaxIdle=10
Postgres__MaxLifetime=
Cache__0__Host=localhost:6379
Cache__0__Type=node
Cache__0__Pass=
Cache__0__Tls=false
Cache__0__User=default

# --- App overrides (optional) ---
# Overrides Config.DataPath if you want to point to a different data dir.
DataPath=../mcp/data

# --- Local development helpers (optional) ---
# Set a less permissive CORS origin for local testing, if desired.
# Example: http://localhost:3000
# CORS__AllowOrigins=

# --- System environment (used by etc/nof0.yaml overrides) ---
# Accepts: test, dev, prod. Defaults to test if unset.
# In test mode, LLM defaults to google/gemini-2.5-flash-lite for low cost.
ENV=
